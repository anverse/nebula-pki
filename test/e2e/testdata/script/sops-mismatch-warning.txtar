# When inline recipients change between runs, every existing encrypted artifact
# triggers a persistent warning directing the operator to run `nebula-pki reencrypt`.
# The run itself is still a noop: no key files are re-encrypted automatically.

[!exec:sops] skip 'sops not in PATH'

# Run 1: generate with age recipient A. Use the known test keypair so run 2
# can decrypt the CA key (needed even on a noop run when hosts are present).
env SOPS_AGE_KEY=AGE-SECRET-KEY-1Y9PD7EAXE79XA5QEY04D7EM0X7A2F6UGQD3RAKENAYUPZQCH5ZFQ4DGP4N
exec nebula-pki
stderr '^generated CA "test-ca"'
stderr 'key:  out/ca/test-ca\.key\.enc'
stderr 'signed host "alpha"'

# Switch to a different age recipient (key B) without touching any artifacts.
cp nebula.v2.hcl nebula.hcl

# Run 2: all artifacts are noop but recipients changed — warning for CA and host.
exec nebula-pki
stderr '^up to date; nothing to do$'
stderr 'warning: CA "test-ca" key was encrypted with different recipients'
stderr 'warning: host "alpha" key was encrypted with different recipients'
stderr 'nebula-pki reencrypt'
! stdout .

# No files were rewritten.
! stderr 'generated'
! stderr 'signed host'
! stderr 'wrote manifest'

-- nebula.hcl --
ca "test-ca" {
  name = "test-ca"
}

host "alpha" {
  networks = ["10.0.0.1/16"]
}

storage {
  encryption "sops" {
    age = ["age1rtertzj2zyt36nl3lp8cqlcjgq3e584lhfurv7rf7fmyld4ldcese49nj9"]
  }
}

-- nebula.v2.hcl --
ca "test-ca" {
  name = "test-ca"
}

host "alpha" {
  networks = ["10.0.0.1/16"]
}

storage {
  encryption "sops" {
    age = ["age1ylsajqmdg4kd7u7s6mn6vxt35llrrpwj7nj578qcsx78g72w8uhqdzstdt"]
  }
}
