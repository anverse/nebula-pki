# Changing inline sops recipients triggers a mismatch warning. Running
# `nebula-pki rekey` re-encrypts the affected key files and clears the warning.

[!exec:sops] skip 'sops not in PATH'

# Inject the age private key for key A (the initial recipient).
env SOPS_AGE_KEY=AGE-SECRET-KEY-1Y9PD7EAXE79XA5QEY04D7EM0X7A2F6UGQD3RAKENAYUPZQCH5ZFQ4DGP4N

# Run 1: generate CA and sign host with key A as the sops recipient.
exec nebula-pki
stderr '^generated CA "test-ca"'
stderr 'key:  out/ca/test-ca\.key\.enc'
stderr '^signed host "alpha"'
stderr 'key:  out/hosts/alpha\.key\.enc'
! stdout .

# Snapshot encrypted key files before rekeying.
cp out/ca/test-ca.key.enc   ca.key.enc.snap
cp out/hosts/alpha.key.enc  alpha.key.enc.snap

# Switch config to key B as recipient. Recipients hash in manifest still reflects key A.
cp nebula.v2.hcl nebula.hcl

# Run 2: noop, but mismatch warning fires for both artifacts.
exec nebula-pki
stderr '^up to date; nothing to do$'
stderr 'warning: CA "test-ca" key was encrypted with different recipients'
stderr 'warning: host "alpha" key was encrypted with different recipients'
stderr 'nebula-pki rekey'
! stdout .

# Rekey: decrypt with key A (SOPS_AGE_KEY still set), re-encrypt for key B recipient.
exec nebula-pki rekey
stdout '2 key files rekeyed'
! stderr .

# Ciphertext changed on disk.
! cmp out/ca/test-ca.key.enc  ca.key.enc.snap
! cmp out/hosts/alpha.key.enc alpha.key.enc.snap

# Run 3 with key B config: noop, no mismatch warning.
exec nebula-pki
stderr '^up to date; nothing to do$'
! stderr 'warning:'
! stdout .

-- nebula.hcl --
ca "test-ca" {
  name = "test-ca"
}

host "alpha" {
  networks = ["10.0.0.1/16"]
}

storage {
  encryption "sops" {
    age = ["age1rtertzj2zyt36nl3lp8cqlcjgq3e584lhfurv7rf7fmyld4ldcese49nj9"]
  }
}

-- nebula.v2.hcl --
ca "test-ca" {
  name = "test-ca"
}

host "alpha" {
  networks = ["10.0.0.1/16"]
}

storage {
  encryption "sops" {
    age = ["age1ylsajqmdg4kd7u7s6mn6vxt35llrrpwj7nj578qcsx78g72w8uhqdzstdt"]
  }
}
