# Removing the encryption block after a sops run is detected as an encryption
# configuration change and blocked with a clear error. The manifest records
# the encrypted key path; the current config expects the plaintext path.

[!exec:sops] skip 'sops not in PATH'

# Run 1: generate with sops. CA key written as mesh.key.enc.
exec nebula-pki
stderr 'generated CA'
exists out/ca/mesh.crt
exists out/ca/mesh.key.enc
! exists out/ca/mesh.key

# Snapshot all artifacts to verify they are untouched after the failed run 2.
cp out/ca/mesh.crt     mesh.crt.snap
cp out/ca/mesh.key.enc mesh.key.enc.snap
cp out/nebula-pki.json manifest.snap

# Switch to no-encryption config. The manifest still records
# key_path: out/ca/mesh.key.enc but the current config expects out/ca/mesh.key.
cp nebula.none.hcl nebula.hcl

# Run 2 must exit non-zero with a clear error; no files are touched.
! exec nebula-pki
stderr 'encryption configuration changed'
stderr 'mesh\.key\.enc'
stderr 'mesh\.key'
stderr 'nebula-pki reencrypt'
! stdout .

# All artifacts are byte-identical to after run 1.
cmp out/ca/mesh.crt     mesh.crt.snap
cmp out/ca/mesh.key.enc mesh.key.enc.snap
cmp out/nebula-pki.json manifest.snap
! exists out/ca/mesh.key

-- nebula.hcl --
ca "mesh" {
  name = "mesh"
}

storage {
  encryption "sops" {
    age = ["age1ylsajqmdg4kd7u7s6mn6vxt35llrrpwj7nj578qcsx78g72w8uhqdzstdt"]
  }
}

-- nebula.none.hcl --
ca "mesh" {
  name = "mesh"
}
