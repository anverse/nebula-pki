# A half-present CA pair — exactly one of cert/key on disk — is the
# scariest state to be in: regenerating would either leak whichever
# survived, or mismatch a key that other parties trust. The tool refuses
# and tells the user which file to remove to recover.

# Cert without key.
mkdir out/ca
cp seed-cert out/ca/ca.crt

! exec nebula-pki
stderr 'inconsistent CA state'
stderr 'certificate out/ca/ca\.crt exists but key out/ca/ca\.key is missing'
stderr 'remove the certificate to regenerate the pair'

# The pre-seeded cert is left exactly as it was.
cmp out/ca/ca.crt seed-cert
! exists out/ca/ca.key
! exists out/nebula-pki.json

# Mirror: key without cert. Reset, swap which file is present.
rm out/ca/ca.crt
cp seed-key out/ca/ca.key

! exec nebula-pki
stderr 'inconsistent CA state'
stderr 'key out/ca/ca\.key exists but certificate out/ca/ca\.crt is missing'
stderr 'remove the key to regenerate the pair'

cmp out/ca/ca.key seed-key
! exists out/ca/ca.crt
! exists out/nebula-pki.json

-- nebula.hcl --
ca {
  name = "test-mesh"
}

-- seed-cert --
PRE-EXISTING CERT BYTES
-- seed-key --
PRE-EXISTING KEY BYTES
