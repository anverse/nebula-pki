# `nebula-pki` with no args reconciles the CA and host certs declared in
# ./nebula.hcl. This script covers the basic generate-mode path: a fresh
# tree gets a CA and one host cert on the first run.

exec nebula-pki
stdout '^generated CA "test-mesh"$'
stdout '^  cert: out/ca/ca\.crt$'
stdout '^  key:  out/ca/ca\.key$'
stdout '^signed host "alpha"$'
stdout '^  cert: out/hosts/alpha\.crt$'
stdout '^  key:  out/hosts/alpha\.key$'
stdout '^wrote manifest: out/nebula-pki\.json$'
! stderr .

# CA and host artifacts exist.
exists out/ca/ca.crt
exists out/ca/ca.key
exists out/hosts/alpha.crt
exists out/hosts/alpha.key
exists out/nebula-pki.json

# Real PEM material was written.
grep 'NEBULA CERTIFICATE' out/ca/ca.crt
grep 'NEBULA ED25519 PRIVATE KEY' out/ca/ca.key
grep 'NEBULA CERTIFICATE' out/hosts/alpha.crt
grep 'NEBULA ED25519 PRIVATE KEY' out/hosts/alpha.key

# Manifest shape: schema, generator, CA record, host record, relative config path.
grep '"schema_version": 1' out/nebula-pki.json
grep '"name": "nebula-pki"' out/nebula-pki.json
grep '"version": "v0\.0\.1-test"' out/nebula-pki.json
grep '"mode": "generate"' out/nebula-pki.json
grep '"name": "test-mesh"' out/nebula-pki.json
grep '"curve": "25519"' out/nebula-pki.json
grep '"config_path": "\.\./nebula\.hcl"' out/nebula-pki.json
grep '"cert_path": "out/ca/ca\.crt"' out/nebula-pki.json
grep '"key_path": "out/ca/ca\.key"' out/nebula-pki.json
grep '"alpha"' out/nebula-pki.json
grep '"ca_fingerprint"' out/nebula-pki.json

-- nebula.hcl --
ca {
  name = "test-mesh"
}

host "alpha" {
  networks = ["10.0.0.1/16"]
}
