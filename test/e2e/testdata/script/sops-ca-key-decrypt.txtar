# On a rerun where the CA is already encrypted on disk, nebula-pki decrypts
# the CA key in-memory (no plaintext file written) and uses it to sign a new
# host. sops is invoked only for the host that needs signing, not on no-op runs.

[!exec:sops] skip 'sops not in PATH'

# Inject the age private key matching the public key used in the HCL below.
env SOPS_AGE_KEY=AGE-SECRET-KEY-1Y9PD7EAXE79XA5QEY04D7EM0X7A2F6UGQD3RAKENAYUPZQCH5ZFQ4DGP4N

# Run 1: generate CA and sign host alpha. Both keys are encrypted.
exec nebula-pki
stderr '^generated CA "test-ca" \(test-ca\)$'
stderr '^  key:  out/ca/test-ca\.key\.enc$'
stderr '^signed host "alpha"$'
stderr '^  key:  out/hosts/alpha\.key\.enc$'
! stdout .

# Snapshot the first-run artifacts.
cp out/ca/test-ca.crt     ca.crt.snap
cp out/ca/test-ca.key.enc ca.key.enc.snap

# Switch to the v2 config that adds host beta.
cp nebula.v2.hcl nebula.hcl

# Run 2: CA is noop (key decrypted in-memory); only beta needs signing.
exec nebula-pki
! stderr 'generated CA'
! stderr 'not yet supported'
! stderr 'v0\.1\.2'
stderr '^signed host "beta"$'
stderr '^  key:  out/hosts/beta\.key\.enc$'
! stdout .

# CA artifacts are byte-identical to run 1.
cmp out/ca/test-ca.crt     ca.crt.snap
cmp out/ca/test-ca.key.enc ca.key.enc.snap

# Alpha is unchanged.
exists out/hosts/alpha.crt
exists out/hosts/alpha.key.enc

# Beta was signed and encrypted.
exists out/hosts/beta.crt
exists out/hosts/beta.key.enc
! grep 'NEBULA ED25519 PRIVATE KEY' out/hosts/beta.key.enc

-- nebula.hcl --
ca "test-ca" {
  name = "test-ca"
}

host "alpha" {
  networks = ["10.0.0.1/16"]
}

storage {
  encryption "sops" {
    age = ["age1rtertzj2zyt36nl3lp8cqlcjgq3e584lhfurv7rf7fmyld4ldcese49nj9"]
  }
}

-- nebula.v2.hcl --
ca "test-ca" {
  name = "test-ca"
}

host "alpha" {
  networks = ["10.0.0.1/16"]
}

host "beta" {
  networks = ["10.0.0.2/16"]
}

storage {
  encryption "sops" {
    age = ["age1rtertzj2zyt36nl3lp8cqlcjgq3e584lhfurv7rf7fmyld4ldcese49nj9"]
  }
}
