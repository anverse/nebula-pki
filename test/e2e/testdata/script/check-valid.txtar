# `nebula-pki check` parses + validates the supplied HCL configuration.

# --- Happy path: minimal generate-mode config validates. ----------------------
exec nebula-pki check -c minimal.hcl
stdout '^config valid: minimal\.hcl \(ca mode=generate, hosts=0\)$'
! stderr .

# Default config path is ./nebula.hcl when -c is omitted.
exec nebula-pki check
stdout '^config valid: nebula\.hcl \(ca mode=generate, hosts=2\)$'
! stderr .

# --- Reference mode: check reads the referenced CA and reports it. ------------
# First mint a real CA so reference.hcl has something coherent to point at.
exec nebula-pki -c gen.hcl
exists out/ca/ca.crt
exists out/ca/ca.key

# check in reference mode validates AND verifies the referenced CA.
exec nebula-pki check -c reference.hcl
stdout '^config valid: reference\.hcl \(ca mode=reference, hosts=0\)$'
stdout '^  ca verified: name="ext-mesh" fingerprint=[0-9a-f]+$'
! stderr .

-- minimal.hcl --
ca {
  name = "test-mesh"
}

-- nebula.hcl --
ca {
  name = "test-mesh"
}

host "alpha" {
  networks = ["10.0.0.1/16"]
}

host "beta" {
  networks = ["10.0.0.2/16"]
}

-- gen.hcl --
ca {
  name = "ext-mesh"
}

-- reference.hcl --
ca {
  cert_file = "out/ca/ca.crt"
  key_file  = "out/ca/ca.key"
}
