# External backend using the age CLI. Demonstrates the {{.InPath}} + stdout
# pattern: age reads from the temp input file and writes ciphertext to stdout.
# On rerun the CA key is decrypted in-memory (no plaintext file written) and
# used to sign a new host.
#
# Uses the same throwaway age keypair as the sops tests. The private key is
# written to age.key in the test directory and passed via --identity.

[!exec:age] skip 'age not in PATH'

# Run 1: generate CA and sign host alpha. Both keys encrypted via age.
exec nebula-pki
stderr '^generated CA "test-ca"'
stderr 'key:  out/ca/test-ca\.key\.enc'
stderr '^signed host "alpha"'
stderr 'key:  out/hosts/alpha\.key\.enc'
! stdout .

exists out/ca/test-ca.crt
exists out/ca/test-ca.key.enc
exists out/hosts/alpha.crt
exists out/hosts/alpha.key.enc

# The encrypted key must not contain a plaintext PEM header.
! grep 'NEBULA ED25519 PRIVATE KEY' out/ca/test-ca.key.enc
! grep 'NEBULA ED25519 PRIVATE KEY' out/hosts/alpha.key.enc

# Snapshot first-run CA artifacts.
cp out/ca/test-ca.crt      ca.crt.snap
cp out/ca/test-ca.key.enc  ca.key.enc.snap

# Run 2: add host beta. CA key decrypted via age --decrypt; beta signed.
cp nebula.v2.hcl nebula.hcl
exec nebula-pki
! stderr 'generated CA'
stderr '^signed host "beta"'
stderr 'key:  out/hosts/beta\.key\.enc'
! stdout .

# CA artifacts are byte-identical to run 1.
cmp out/ca/test-ca.crt     ca.crt.snap
cmp out/ca/test-ca.key.enc ca.key.enc.snap

exists out/hosts/beta.crt
exists out/hosts/beta.key.enc
! grep 'NEBULA ED25519 PRIVATE KEY' out/hosts/beta.key.enc

# Run 3: full noop.
exec nebula-pki
stderr '^up to date; nothing to do$'

-- age.key --
# created: 2026-07-16T00:00:00Z
# public key: age1rtertzj2zyt36nl3lp8cqlcjgq3e584lhfurv7rf7fmyld4ldcese49nj9
AGE-SECRET-KEY-1Y9PD7EAXE79XA5QEY04D7EM0X7A2F6UGQD3RAKENAYUPZQCH5ZFQ4DGP4N

-- nebula.hcl --
ca "test-ca" {
  name = "test-ca"
}

host "alpha" {
  networks = ["10.0.0.1/16"]
}

storage {
  encryption "external" {
    encrypt_command = ["age", "--encrypt", "--recipient", "age1rtertzj2zyt36nl3lp8cqlcjgq3e584lhfurv7rf7fmyld4ldcese49nj9", "{{.InPath}}"]
    decrypt_command = ["age", "--decrypt", "--identity", "age.key", "{{.InPath}}"]
  }
}

-- nebula.v2.hcl --
ca "test-ca" {
  name = "test-ca"
}

host "alpha" {
  networks = ["10.0.0.1/16"]
}

host "beta" {
  networks = ["10.0.0.2/16"]
}

storage {
  encryption "external" {
    encrypt_command = ["age", "--encrypt", "--recipient", "age1rtertzj2zyt36nl3lp8cqlcjgq3e584lhfurv7rf7fmyld4ldcese49nj9", "{{.InPath}}"]
    decrypt_command = ["age", "--decrypt", "--identity", "age.key", "{{.InPath}}"]
  }
}
