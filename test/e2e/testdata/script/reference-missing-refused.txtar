# Reference mode names cert_file / key_file that do not exist. The tool
# must fail loudly rather than silently producing an empty manifest.

# check reports the config itself as valid (the HCL parses), then fails on
# the missing CA file. The "config valid:" line is scoped to the
# configuration; it does not claim the whole check passed.
! exec nebula-pki check -c reference.hcl
stdout '^config valid: reference\.hcl \(cas=1, hosts=0\)$'
! stdout 'verified:'
stderr 'read referenced CA certificate'

# Reconcile refuses too, naming the missing file.
! exec nebula-pki -c reference.hcl
stderr 'referenced CA not found'

# Nothing was written.
! exists out

-- reference.hcl --
ca "ref" {
  cert_file = "absent.crt"
  key_file  = "absent.key"
}
