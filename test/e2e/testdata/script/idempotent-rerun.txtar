# Reconciling an unchanged tree a second time must write nothing — not even
# the manifest — so the committed output stays byte-identical across runs.

# First run: CA and host cert are created.
exec nebula-pki
stdout '^generated CA "test-mesh"$'
stdout '^signed host "alpha"$'
! stderr .

# Snapshot every artifact.
cp out/ca/ca.crt ca.crt.first
cp out/ca/ca.key ca.key.first
cp out/hosts/alpha.crt alpha.crt.first
cp out/hosts/alpha.key alpha.key.first
cp out/nebula-pki.json manifest.first

# Second run must report "up to date" and touch nothing.
exec nebula-pki
stdout '^up to date; nothing to write$'
! stdout 'generated CA'
! stdout 'signed host'
! stderr .

# All artifacts are byte-identical to the first run.
cmp out/ca/ca.crt ca.crt.first
cmp out/ca/ca.key ca.key.first
cmp out/hosts/alpha.crt alpha.crt.first
cmp out/hosts/alpha.key alpha.key.first
cmp out/nebula-pki.json manifest.first

-- nebula.hcl --
ca {
  name = "test-mesh"
}

host "alpha" {
  networks = ["10.0.0.1/16"]
}
