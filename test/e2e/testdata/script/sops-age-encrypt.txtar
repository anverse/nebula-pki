# `nebula-pki` with sops age encryption writes encrypted key files and leaves
# plaintext keys absent. Certs remain unencrypted. The manifest records the
# on-disk paths (including the .enc suffix) and the encryption backend.

[!exec:sops] skip 'sops not in PATH'

exec nebula-pki
stderr '^generated CA "test-ca" \(test-ca\)$'
stderr '^  cert: out/ca/test-ca\.crt$'
stderr '^  key:  out/ca/test-ca\.key\.enc$'
stderr '^signed host "alpha"$'
stderr '^  cert: out/hosts/alpha\.crt$'
stderr '^  key:  out/hosts/alpha\.key\.enc$'
stderr '^wrote manifest: out/nebula-pki\.json$'
! stdout .

# Encrypted key files present; plaintext keys absent.
exists out/ca/test-ca.crt
exists out/ca/test-ca.key.enc
! exists out/ca/test-ca.key
exists out/hosts/alpha.crt
exists out/hosts/alpha.key.enc
! exists out/hosts/alpha.key
exists out/nebula-pki.json

# Certs are plaintext PEM; encrypted key files are not.
grep 'NEBULA CERTIFICATE' out/ca/test-ca.crt
grep 'NEBULA CERTIFICATE' out/hosts/alpha.crt
! grep 'NEBULA ED25519 PRIVATE KEY' out/ca/test-ca.key.enc
! grep 'NEBULA ED25519 PRIVATE KEY' out/hosts/alpha.key.enc

# Manifest records the encrypted key paths and backend.
grep '"key_path": "out/ca/test-ca\.key\.enc"' out/nebula-pki.json
grep '"backend": "sops"' out/nebula-pki.json
grep '"suffix": "\.enc"' out/nebula-pki.json

-- nebula.hcl --
ca "test-ca" {
  name = "test-ca"
}

host "alpha" {
  networks = ["10.0.0.1/16"]
}

storage {
  encryption "sops" {
    age = ["age1ylsajqmdg4kd7u7s6mn6vxt35llrrpwj7nj578qcsx78g72w8uhqdzstdt"]
  }
}
